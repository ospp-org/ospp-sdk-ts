{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ospp-standard.org/schemas/v1/mqtt/transaction-event-request.schema.json",
  "title": "TransactionEventRequest",
  "description": "MQTT message sent by a station to report a completed offline transaction for server-side reconciliation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "offlineTxId",
    "userId",
    "bayId",
    "serviceId",
    "startedAt",
    "endedAt",
    "durationSeconds",
    "creditsCharged",
    "receipt",
    "txCounter"
  ],
  "oneOf": [
    {
      "title": "pass-form (Full Offline / Partial B)",
      "required": ["offlinePassId", "passCounter"],
      "properties": { "authId": false, "sessionId": false }
    },
    {
      "title": "auth-form (Partial A — ServerSignedAuth)",
      "required": ["authId", "sessionId"],
      "properties": { "offlinePassId": false, "passCounter": false }
    }
  ],
  "properties": {
    "offlineTxId": {
      "$ref": "../common/offline-tx-id.schema.json"
    },
    "offlinePassId": {
      "$ref": "../common/offline-pass-id.schema.json"
    },
    "passCounter": {
      "type": "integer",
      "minimum": 0,
      "description": "Pass-form only. Envelope copy of the pass's app-global usage counter (finding N7). MUST equal the signed receipt's passCounter (reconcile gate §6.1 check #12); the gate then enforces global (offlinePassId, passCounter) uniqueness (check #13)."
    },
    "authId": {
      "type": "string",
      "pattern": "^auth_[a-f0-9]{8,}$",
      "minLength": 13,
      "maxLength": 64,
      "description": "Auth-form (Partial A) only. Envelope copy of the ServerSignedAuth authId; MUST equal the signed receipt's authId (gate §6.1 check #2 auth-branch). The gate resolves it against the issued-authorization registry (check #4 auth-branch)."
    },
    "sessionId": {
      "$ref": "../common/session-id.schema.json",
      "description": "Auth-form (Partial A) only. Envelope copy of the server-issued sessionId the transaction settles; MUST equal the signed receipt's sessionId."
    },
    "userId": {
      "$ref": "../common/user-id.schema.json"
    },
    "bayId": {
      "$ref": "../common/bay-id.schema.json"
    },
    "serviceId": {
      "$ref": "../common/service-id.schema.json"
    },
    "startedAt": {
      "$ref": "../common/timestamp.schema.json"
    },
    "endedAt": {
      "$ref": "../common/timestamp.schema.json"
    },
    "durationSeconds": {
      "type": "integer",
      "minimum": 1
    },
    "creditsCharged": {
      "$ref": "../common/credit-amount.schema.json"
    },
    "receipt": {
      "$ref": "../common/receipt.schema.json"
    },
    "txCounter": {
      "type": "integer",
      "minimum": 1
    },
    "meterValues": {
      "$ref": "../common/meter-values.schema.json"
    }
  }
}
