{
  "name": "@ospp/protocol",
  "version": "0.1.0",
  "description": "OSPP Protocol TypeScript SDK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ospp-org/ospp-sdk-ts.git"
  },
  "bugs": {
    "url": "https://github.com/ospp-org/ospp-sdk-ts/issues"
  },
  "homepage": "https://github.com/ospp-org/ospp-sdk-ts#readme",
  "keywords": ["ospp", "mqtt", "protocol", "typescript", "sdk"],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/schemas"
  ],
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/schemas/**/*.schema.json\" dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "copyfiles": "^2.4.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
